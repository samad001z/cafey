VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_GOOGLE_PLACES_API_KEY=your-google-places-api-key
VITE_GOOGLE_PLACE_ID=your-google-place-id
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GOOGLE_PLACE_ID=your-google-place-id

# Customer OTP mode: supabase (default) or twilio
VITE_OTP_PROVIDER=supabase
VITE_OTP_API_BASE_URL=http://localhost:8787
# In Vercel production with serverless API routes, leave VITE_OTP_API_BASE_URL empty.

# Twilio Verify server config
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OTP_SERVER_PORT=8787
OTP_ALLOWED_ORIGIN=http://localhost:5173

# Secure server-side credentials (never expose service role in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DEMO_ADMIN_EMAIL=owner@qaffeine.com
DEMO_ADMIN_PASSWORD=12345678
VITE_DEMO_ADMIN_EMAIL=owner@qaffeine.com
VITE_DEMO_ADMIN_PASSWORD=12345678
DEMO_STAFF_EMPLOYEE_ID=EMP-1001
DEMO_STAFF_EMAIL=emp-1001@qaffeine.internal
DEMO_STAFF_PASSWORD=12345678
DEMO_STAFF_PHONE=+919999999999
VITE_DEMO_STAFF_EMPLOYEE_ID=EMP-1001
VITE_DEMO_STAFF_PASSWORD=12345678
